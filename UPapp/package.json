{
  "name": "upapp",
  "version": "1.0.0",
  "description": "NVC Forms Management Application",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && /c/xampp/php/php.exe -S localhost:8080 -t public",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "gui": "python scripts/gui/launcher.py",
    "db:create": "bash scripts/dynamodb/create-tables.sh dev",
    "db:seed": "/c/xampp/php/php.exe scripts/dynamodb/seed-data.php",
    "deploy": "node scripts/deploy/sftp-upload.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
