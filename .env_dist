# App Configuration
APP_ENV=dev                            # Environment: dev | uat | prod
APP_URL=http://localhost:5173          # Frontend URL

# AWS Configuration
AWS_REGION=eu-central-1                # AWS region for DynamoDB
AWS_ACCESS_KEY_ID=                     # Leave empty to use AWS CLI profile
AWS_SECRET_ACCESS_KEY=                 # Leave empty to use AWS CLI profile

# DynamoDB
DYNAMODB_TABLE_PREFIX=UpApp            # Table naming prefix (UpApp.<ENV>.<tablename>)

# Backend API
BACKEND_URL=http://localhost:8080      # Backend API base URL

# Auth - Google OAuth (Future feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com               # SMTP server host
SMTP_PORT=587                          # SMTP port (587 for TLS, 465 for SSL)
SMTP_USERNAME=                         # SMTP username
SMTP_PASSWORD=                         # SMTP password or app-specific password
SMTP_FROM_EMAIL=noreply@upapp.local    # Sender email address
SMTP_FROM_NAME=UPapp                   # Sender name

# Auth - Magic Link (Future feature)
MAGIC_LINK_SECRET=
MAGIC_LINK_TTL_MINUTES=15

# Admin (Future feature)
ADMIN_EMAIL=janczewski.piotr@gmail.com
ADMIN_ALLOWED_EMAILS=janczewski.piotr@gmail.com

# SFTP Deployment (Future feature)
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_REMOTE_PATH=/var/www/upapp
SFTP_KEY_PATH=~/.ssh/id_rsa
