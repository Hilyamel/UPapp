# App Configuration
APP_ENV=dev                            # Environment: dev | uat | prod
APP_URL=http://localhost:5173          # Frontend URL

# AWS Configuration
AWS_REGION=eu-central-1                # AWS region for DynamoDB
AWS_ACCESS_KEY_ID=                     # Leave empty to use AWS CLI profile
AWS_SECRET_ACCESS_KEY=                 # Leave empty to use AWS CLI profile

# DynamoDB
DYNAMODB_TABLE_PREFIX=UpApp            # Table naming prefix (UpApp.<ENV>.<tablename>)

# Backend API
BACKEND_URL=http://localhost:8080      # Backend API base URL

# Anthropic Claude API
ANTHROPIC_API_KEY=                     # Your Anthropic API key for empAItyczne feedback

# Auth - Google OAuth (Future feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email Configuration (SMTP) - FILL IN YOUR CREDENTIALS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=                         # Your email address
SMTP_PASSWORD=                         # Your SMTP password or app-specific password
SMTP_FROM_EMAIL=                       # From email address
SMTP_FROM_NAME=UPapp

# Auth - Magic Link (Future feature)
MAGIC_LINK_SECRET=
MAGIC_LINK_TTL_MINUTES=15

# Admin (Future feature)
ADMIN_EMAIL=                           # Admin email address
ADMIN_ALLOWED_EMAILS=                  # Comma-separated list of allowed admin emails

# FTP Deployment (Production)
FTP_HOST=                              # FTP server hostname
FTP_PORT=21
FTP_USER=                              # FTP username
FTP_PASSWORD=                          # FTP password
FTP_REMOTE_PATH=/                      # Remote path on FTP server

# Database (Production - dhosting.pl)
DB_HOST=                               # MySQL server hostname
DB_NAME=                               # Database name
DB_USER=                               # Database username
DB_PASSWORD=                           # Database password
