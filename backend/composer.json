{
    "name": "upapp/backend",
    "description": "UPapp Backend API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.290",
        "phpmailer/phpmailer": "^6.9",
        "ramsey/uuid": "^4.9",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "UpApp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UpApp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs --standard=PSR12 src/",
        "lint:fix": "phpcbf --standard=PSR12 src/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    }
}
