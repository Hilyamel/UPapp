# Production Environment Configuration
# Copy this to .env on production server and fill in actual values
# NEVER commit .env files with real credentials!

APP_ENV=prod
APP_URL=https://przetargr-domow.pl

# AWS Configuration
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-aws-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-here

# DynamoDB
DYNAMODB_TABLE_PREFIX=UpApp

# Backend API
BACKEND_URL=https://przetargr-domow.pl/api

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=UPapp

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
EMPATHY_PROMPT_PATH=empathy-prompt.txt

# Database (MySQL) - if needed for future features
DB_HOST=your-mysql-host
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
